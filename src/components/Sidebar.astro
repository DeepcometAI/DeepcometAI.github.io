---
import { getCollection } from 'astro:content';
const docs = await getCollection('docs');
docs.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));
---
<aside class="w-full md:w-64 flex-shrink-0 md:border-r border-gray-200 dark:border-gray-800 md:pr-6 md:sticky md:top-24 md:h-[calc(100vh-6rem)] overflow-y-auto">
  <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-4 uppercase tracking-wider text-sm">Documentation</h3>
  <ul class="space-y-2">
    {docs.map(doc => (
      <li>
        <a href={`/docs/${doc.slug}`} class="text-gray-600 dark:text-gray-400 hover:text-deepcomet-accent dark:hover:text-deepcomet-accent text-sm transition-colors block py-1">
          {doc.data.title}
        </a>
      </li>
    ))}
  </ul>
</aside>
