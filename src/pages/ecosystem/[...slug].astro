---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const items = await getCollection('ecosystem');
  return items.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---
<Layout title={entry.data.title}>
  <article class="prose dark:prose-invert prose-blue max-w-3xl mx-auto py-12">
    <span class="text-sm font-bold text-deepcomet-accent uppercase tracking-wider">{entry.data.category}</span>
    <Content />
  </article>
</Layout>
