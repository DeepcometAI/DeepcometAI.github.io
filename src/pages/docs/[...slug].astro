---
import { getCollection } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
---
<DocsLayout title={entry.data.title} headings={headings}>
  <article class="prose dark:prose-invert prose-blue max-w-none">
    <h1>{entry.data.title}</h1>
    <p class="lead text-xl text-gray-600 dark:text-gray-400">{entry.data.description}</p>
    <hr class="my-8 border-gray-200 dark:border-gray-800" />
    <Content />
  </article>
</DocsLayout>
