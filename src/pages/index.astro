---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
---

<Layout title="Home">
  <Hero />
  
  <!-- Stats Section -->
  <section class="py-12 border-t border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-800/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div class="animate-fade-in-up" style="animation-delay: 0.1s">
          <div class="text-4xl md:text-5xl font-extrabold text-deepcomet-accent mb-2">10x</div>
          <div class="text-xs md:text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Faster Compilation</div>
        </div>
        <div class="animate-fade-in-up" style="animation-delay: 0.2s">
          <div class="text-4xl md:text-5xl font-extrabold text-deepcomet-accent mb-2">0ms</div>
          <div class="text-xs md:text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Scheduling Latency</div>
        </div>
        <div class="animate-fade-in-up" style="animation-delay: 0.3s">
          <div class="text-4xl md:text-5xl font-extrabold text-deepcomet-accent mb-2">100%</div>
          <div class="text-xs md:text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Memory Safe</div>
        </div>
        <div class="animate-fade-in-up" style="animation-delay: 0.4s">
          <div class="text-4xl md:text-5xl font-extrabold text-deepcomet-accent mb-2">Native</div>
          <div class="text-xs md:text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">NPU Integration</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Code Showcase Section -->
  <section class="py-20 border-t border-gray-200 dark:border-gray-800">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="animate-fade-in-up">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Built for the AI Era</h2>
        <p class="text-lg text-gray-600 dark:text-gray-400 mb-6 leading-relaxed">
          Aurelia isn't just another language. It treats neural networks as first-class citizens. With native tensor primitives, automatic differentiation, and direct MLIR compilation, you write less code and get more performance.
        </p>
        <ul class="space-y-4 mb-8">
          <li class="flex items-start">
            <svg class="w-6 h-6 text-green-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-gray-700 dark:text-gray-300"><strong>First-class Tensors:</strong> No more clunky library wrappers.</span>
          </li>
          <li class="flex items-start">
            <svg class="w-6 h-6 text-green-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-gray-700 dark:text-gray-300"><strong>Memory Safety:</strong> Compile-time guarantees without a garbage collector.</span>
          </li>
          <li class="flex items-start">
            <svg class="w-6 h-6 text-green-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-gray-700 dark:text-gray-300"><strong>Direct NPU Targeting:</strong> Bypass CPU bottlenecks entirely.</span>
          </li>
        </ul>
        <a href="/docs/aurelia-intro" class="inline-flex items-center text-deepcomet-accent font-semibold hover:text-blue-600 transition-colors group">
          Read the Aurelia Docs <svg class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </a>
      </div>
      <div class="relative group animate-fade-in-up" style="animation-delay: 0.2s">
        <div class="absolute -inset-1 bg-gradient-to-r from-deepcomet-accent to-purple-600 rounded-xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
        <div class="relative bg-[#0d1117] rounded-xl p-6 border border-gray-800 shadow-2xl overflow-hidden">
          <div class="flex items-center gap-2 mb-4 border-b border-gray-800 pb-4">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
            <span class="ml-2 text-xs text-gray-500 font-mono">neural_layer.aul</span>
          </div>
          <pre class="text-sm font-mono text-gray-300 overflow-x-auto"><code><span class="text-purple-400">fn</span> <span class="text-blue-400">forward_pass</span>(x: <span class="text-yellow-300">Tensor</span>&lt;f32, <span class="text-orange-300">2</span>&gt;) -&gt; <span class="text-yellow-300">Tensor</span>&lt;f32, <span class="text-orange-300">2</span>&gt; &#123;
  <span class="text-gray-500">// Native tensor operations</span>
  <span class="text-purple-400">let</span> weights = <span class="text-yellow-300">Tensor</span>::random([<span class="text-orange-300">256</span>, <span class="text-orange-300">512</span>]);
  <span class="text-purple-400">let</span> biases = <span class="text-yellow-300">Tensor</span>::zeros([<span class="text-orange-300">512</span>]);
  
  <span class="text-gray-500">// Automatic differentiation built-in</span>
  <span class="text-purple-400">let</span> output = (x @ weights) + biases;
  <span class="text-purple-400">return</span> output.relu();
&#125;

<span class="text-gray-500">// Compiles directly to MLIR -&gt; NPU</span>
<span class="text-purple-400">@target</span>(npu=<span class="text-green-300">"qualcomm-hexagon"</span>)
<span class="text-purple-400">fn</span> <span class="text-blue-400">main</span>() &#123;
  <span class="text-purple-400">let</span> input = <span class="text-yellow-300">Tensor</span>::ones([<span class="text-orange-300">128</span>, <span class="text-orange-300">256</span>]);
  <span class="text-purple-400">let</span> result = forward_pass(input);
&#125;</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- Vertical AI Integration -->
  <section class="py-16 border-t border-gray-200 dark:border-gray-800">
    <div class="text-center mb-12 animate-fade-in-up">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Vertical AI Integration</h2>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">Unlike competitors who run AI workloads on top of general-purpose operating systems, DeepcometAI is building a system where AI is the core.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="p-8 bg-white dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 group animate-fade-in-up" style="animation-delay: 0.1s">
        <div class="w-14 h-14 bg-blue-100 dark:bg-blue-900/50 text-blue-600 dark:text-blue-400 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <h3 class="text-xl font-bold mb-3 group-hover:text-blue-500 transition-colors">Zero-Latency Scheduling</h3>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed">Probabilistic models in the Zenith Kernel anticipate resource needs 10ms before they are required, eliminating latency for high-priority tasks.</p>
      </div>
      
      <div class="p-8 bg-white dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 group animate-fade-in-up" style="animation-delay: 0.2s">
        <div class="w-14 h-14 bg-purple-100 dark:bg-purple-900/50 text-purple-600 dark:text-purple-400 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
        </div>
        <h3 class="text-xl font-bold mb-3 group-hover:text-purple-500 transition-colors">Hardware-Software Synthesis</h3>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed">Aurelia code is compiled directly for the memory and execution characteristics of the NPU via MLIR, maximizing hardware utilization.</p>
      </div>
      
      <div class="p-8 bg-white dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 group animate-fade-in-up" style="animation-delay: 0.3s">
        <div class="w-14 h-14 bg-green-100 dark:bg-green-900/50 text-green-600 dark:text-green-400 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
        </div>
        <h3 class="text-xl font-bold mb-3 group-hover:text-green-500 transition-colors">Intrinsic Security</h3>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed">A kernel mathematically proven safe, with an AI-Watchdog monitoring for anomalous behavior to instantly kill zero-day exploits.</p>
      </div>
    </div>
  </section>

  <!-- Ecosystem Section -->
  <section class="py-16 border-t border-gray-200 dark:border-gray-800">
    <div class="flex flex-col md:flex-row justify-between items-end mb-10 animate-fade-in-up">
      <div>
        <h2 class="text-3xl font-bold mb-3">Explore the Ecosystem</h2>
        <p class="text-lg text-gray-600 dark:text-gray-400">Discover the components powering the next generation of computing.</p>
      </div>
      <a href="/ecosystem" class="text-deepcomet-accent hover:text-blue-600 dark:hover:text-blue-400 font-medium mt-4 md:mt-0 flex items-center gap-1 transition-colors group">
        View all projects <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="animate-fade-in-up" style="animation-delay: 0.1s">
        <Card 
          title="Aurelia Language" 
          description="First-class tensor primitives and native automatic differentiation."
          href="/docs/aurelia-intro"
          tag="Core Tech"
        />
      </div>
      <div class="animate-fade-in-up" style="animation-delay: 0.2s">
        <Card 
          title="Zenith Kernel" 
          description="Microkernel with probabilistic scheduling and immune system."
          href="/ecosystem/deepcomet-zenith"
          tag="OS Layer"
        />
      </div>
      <div class="animate-fade-in-up" style="animation-delay: 0.3s">
        <Card 
          title="SkyOS" 
          description="Generative Operating System powered by Large Action Models."
          href="/docs/skyos"
          tag="Platform"
        />
      </div>
      <div class="animate-fade-in-up" style="animation-delay: 0.4s">
        <Card 
          title="The Forge" 
          description="Automated migration of legacy C++ and Java codebases."
          href="/ecosystem/the-forge"
          tag="Tooling"
        />
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 border-t border-gray-200 dark:border-gray-800 text-center relative overflow-hidden">
    <div class="absolute inset-0 bg-deepcomet-accent/5 dark:bg-deepcomet-accent/10"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-deepcomet-accent/20 rounded-full blur-[100px] opacity-50 pointer-events-none"></div>
    
    <div class="relative z-10 max-w-3xl mx-auto px-4 animate-fade-in-up">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">Ready to build the future?</h2>
      <p class="text-xl text-gray-600 dark:text-gray-300 mb-10">
        Join the Deepcomet AI ecosystem and start building next-generation applications with Aurelia and SkyOS today.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/docs" class="bg-deepcomet-accent hover:bg-blue-600 text-white px-8 py-4 rounded-lg font-bold text-lg transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-blue-500/25">
          Get Started
        </a>
        <a href="https://github.com/Nehal-aditya" target="_blank" rel="noopener noreferrer" class="bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-900 dark:text-white border border-gray-200 dark:border-gray-700 px-8 py-4 rounded-lg font-bold text-lg transition-all duration-300 hover:scale-105 shadow-sm">
          View on GitHub
        </a>
      </div>
    </div>
  </section>
</Layout>
